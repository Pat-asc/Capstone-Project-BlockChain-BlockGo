# ============================================================
# BlockGo Deployment Configuration Template
# ============================================================
# IMPORTANT: Copy this file to .env and fill in the values below.
# NEVER commit the actual .env file to version control.
# 
# For GitHub Actions, these values should be set as repository secrets:
# Settings > Secrets and variables > Actions > New repository secret
# ============================================================

# JWT Configuration
# Generate a strong random string (minimum 32 characters)
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Internal API Key
# Used for inter-service authentication
INTERNAL_API_KEY=your_internal_api_key_here_min_32_chars

# Database Configuration
# PostgreSQL database password (minimum 12 characters recommended)
POSTGRES_PASS=your_postgres_password_here_min_12_chars

# Bootstrap/Admin Credentials
# Used for initial CA bootstrap and admin registration
BOOTSTRAP_REGISTRAR_PASS=your_bootstrap_password_here_min_12_chars

# Mock Registrar Password
# Used for testing and demo purposes
MOCK_REGISTRAR_PASS=your_mock_registrar_password_here_min_12_chars

# CouchDB Configuration (Optional)
COUCHDB_USER=capstone
COUCHDB_PASS=pass123

# ============================================================
# Setup Instructions:
# ============================================================
# 1. Copy this file to .env:
#    cp network/.env.example network/.env
#
# 2. Replace all placeholder values with actual secure values
#
# 3. For local development:
#    Run: source network/.env before executing ./network/full_deploy.sh
#
# 4. For GitHub Actions:
#    Add these variables as repository secrets in GitHub Settings
#    - Settings > Secrets and variables > Actions
#    - Add each secret with its name and value
#
# 5. Password Generation Examples:
#    # Linux/Mac:
#    openssl rand -base64 32    # For JWT_SECRET and INTERNAL_API_KEY
#    openssl rand -base64 16    # For passwords
#
#    # Or use:
#    head -c 32 /dev/urandom | base64
# ============================================================
