---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: pv-orderer-1
spec:
  capacity:
    storage: 20Gi
  volumeMode: Filesystem
  accessModes: [ "ReadWriteOnce" ]
  persistentVolumeReclaimPolicy: Retain
  storageClassName: fabric-storage
  hostPath:
    path: ${PWD}/fabric-k8s-data/orderer-1
    type: DirectoryOrCreate
